{
  "name": "routewatch",
  "version": "0.1.0",
  "description": "Lightweight Express middleware for logging and visualizing API route usage in development",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint src/"
  },
  "keywords": ["express", "middleware", "logging", "routes", "devtools"],
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.57.0",
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=14"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"]
  }
}
